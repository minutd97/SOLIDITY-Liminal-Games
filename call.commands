npx hardhat run scripts/deploy/lpStakingDeploy.js --network arbitrumSepolia

npx hardhat run scripts/deploy/knyBetDeploy.js --network localhost
npx hardhat run scripts/deploy/knyBetDeploy.js --network arbitrumSepolia

npx hardhat run scripts/deploy/limGovernorDeploy.js --network localhost
npx hardhat run scripts/deploy/limGovernorDeploy.js --network arbitrumSepolia
